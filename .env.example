# =============================================================================
# oneint-k8s-mgt — environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your environment:
#
#     cp .env.example .env
#
# Every mage target and Taskfile task loads `.env` (via godotenv / dotenv).
# `.env` is git-ignored — never commit real credentials.
# Values below are safe local/demo defaults suitable for a Kind cluster.
# =============================================================================

# -----------------------------------------------------------------------------
# Debezium Platform versions
# -----------------------------------------------------------------------------
# DBZ_VERSION is REQUIRED (Debezium Helm chart version). See charts.debezium.io.
DBZ_VERSION=3.6.0-cr1
# Container image tag for the operator/platform images (e.g. nightly, or a pin).
DBZ_IMAGE_TAG=nightly
DBZ_IMAGE_TAG_CONDUCTOR=nightly
# Namespace the Debezium Platform is deployed into.
DBZ_NAMESPACE=dmp
# Verbose logging for mage tasks (true|false).
DEBUG=false

# -----------------------------------------------------------------------------
# Cluster selection
# -----------------------------------------------------------------------------
# Cluster provider: kind | k3s
CLUSTER_TYPE=kind
# Deployment environment; selects deploy/values/<component>/<DBZ_ENV>.yaml.
# Known values in this repo: local | erebor | aws | hetzner
# Use `local` for a self-contained Kind demo.
DBZ_ENV=local

# --- Kind (local) -----------------------------------------------------------
KIND_CLUSTER_NAME=dmp
KIND_CONFIG=deploy/clusters/kind/kind-ingress.yaml

# --- K3s (remote, optional; only used when CLUSTER_TYPE=k3s) -----------------
# Connection details for a remote K3s host managed over SSH.
K3S_SSH_USER=youruser
K3S_HOST=192.168.0.10
K3S_SSH_KEY=~/.ssh/id_ed25519
K3S_REMOTE_KUBECONFIG=/tmp/k3s.yaml
K3S_CONTEXT=k3s
K3S_LOCAL_KUBECONFIG=~/.kube/config_k3s

# -----------------------------------------------------------------------------
# Local source-repository paths (only needed to build components from source)
# Point these at your local checkouts of the Debezium Platform repos.
# Not required for the standard chart-based deployment.
# -----------------------------------------------------------------------------
DBZ_PLATFORM_REPO=/path/to/debezium-platform/helm
DBZ_CONDUCTOR_DIR=/path/to/debezium-platform/debezium-platform-conductor
DBZ_STAGE_DIR=/path/to/debezium-platform/debezium-platform-stage
ONEINT_DIR=/path/to/oneint-k8s-mgt

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# Data seeding (mage data:*) — connection to databases from your workstation
# =============================================================================

# --- MongoDB (mage data:mongo) ----------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_USERNAME=app_owner
MONGODB_PASSWORD=app_owner
MONGODB_DATABASE=ecommerce
MONGODB_DIRECT_CONNECTION=true
MONGODB_AUTH_SOURCE=admin

# --- PostgreSQL (mage data:pg) ----------------------------------------------
POSTGRESQL_HOST=127.0.0.1

# =============================================================================
# DMP scenarios (mage scenario:apply ...) — values expanded into JSON payloads
# In-cluster addresses below assume the charts in this repo. Adjust per env.
# =============================================================================

# Debezium Platform API base URL (overrides the hardcoded default in code).
DMP_BASE_URL=http://platform.debezium.local
# Prefix + environment used to build deterministic DMP resource names:
#   ${DMP_RESOURCE_PREFIX}-${DMP_ENVIRONMENT}-<resource-type>
DMP_RESOURCE_PREFIX=oneint
DMP_ENVIRONMENT=local

# --- MongoDB source connection (in-cluster) ---------------------------------
MONGODB_DMP_CONNECTION_STRING=mongodb://debezium:debezium@mongodb-2.mongodb-svc.databases.svc.cluster.local:27017/admin?authSource=admin&replicaSet=mongodb&serverSelectionTimeoutMS=2000

# --- PostgreSQL source connection (in-cluster) ------------------------------
POSTGRES_DMP_HOST=postgresql-rw.databases.svc.cluster.local
POSTGRES_DMP_PORT=5432
POSTGRES_DMP_DATABASE=ecommerce
POSTGRES_DMP_USERNAME=debezium
POSTGRES_DMP_PASSWORD=debezium

# --- Kafka destination (in-cluster) -----------------------------------------
KAFKA_DMP_BOOTSTRAP_SERVERS=my-cluster-kafka-bootstrap.kafka:9092

# --- HTTP-server destination (in-cluster) -----------------------------------
HTTPSERVER_DMP_CONNECTION_STRING=http://http-server.tools.svc.cluster.local

# --- SQL Server source connection (in-cluster) ------------------------------
SQLSERVER_DMP_HOSTNAME=mssql.databases.svc.cluster.local
SQLSERVER_DMP_USERNAME=app_owner
SQLSERVER_DMP_PASSWORD=app_owner
SQLSERVER_DMP_DATABASE=ecommerce
SQLSERVER_DMP_ENCRYPT=false
SQLSERVER_DMP_TRUST_SERVER_CERTIFICATE=true
