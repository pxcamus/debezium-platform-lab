# Local environment / secrets (never commit)
.env
.env.*.local
# but keep the committed template (a global ~/.gitignore may ignore .env*)
!.env.example
*.kubeconfig
kubeconfig*
# Per-release secret overlays (real hosts, tokens, htpasswd hashes)
deploy/values/**/*.secret.yaml

# Symlinked / external working dirs
examples
/kafka/
/docs
/thorin

# IDE
.idea/

# OS
.DS_Store
