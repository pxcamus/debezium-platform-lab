DBZ_VERSION=3.6.0
DBZ_ENV=local
DBZ_NAMESPACE=dmp
DBZ_IMAGE_TAG=nightly
DBZ_IMAGE_TAG_CONDUCTOR=nightly
TIMESTAMP_TEST=2021-09-22T12:00:00Z

# Monitoring stack (homelab only) — see docs/monitoring.md
KUBE_PROMETHEUS_STACK_VERSION=87.10.1
OTEL_OPERATOR_VERSION=0.118.0

# Identity / SSO (homelab only) — Keycloak via the official Operator.
# The operator and the Keycloak server image are lockstep (the operator pins the
# server image via RELATED_IMAGE_KEYCLOAK), so these two normally match.
# After bumping KEYCLOAK_OPERATOR_VERSION, re-run scripts/vendor-keycloak-operator.sh.
KEYCLOAK_VERSION=26.7.0
KEYCLOAK_OPERATOR_VERSION=26.7.0
